# Database
DATABASE_URL="postgresql://user:password@localhost:5432/escrow_db?schema=public"

# Blockchain
# Comma-separated URLs enable FallbackProvider (quorum 1 — tip skew across free RPCs).
# dRPC alone often times out → ethers reports "missing revert data".
# PublicNode alone may reject eth_getLogs as archive. Mix endpoints:
RPC_URL="https://polygon-amoy.gateway.tenderly.co,https://polygon-amoy-bor-rpc.publicnode.com,https://polygon-amoy.drpc.org"
CHAIN_ID=80002
ESCROW_CONTRACT_ADDRESS="0x..."
ERWF_CONTRACT_ADDRESS="0x..."

# Gas Relay / Treasury Wallet
# Pays ALL gas (meta-txs + EIP-2612 permits). Never tops up user wallets.
# Must hold Escrow ADMIN_ROLE (matching Amoy deploy admin/operator).
TREASURY_PRIVATE_KEY="0x..."

# Security
ENCRYPTION_KEY="your-256-bit-encryption-key-here"
PIN_PEPPER="your-pin-pepper-secret-here"

# Admin Authentication
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="8h"
# Idle logout (default 30 min). Absolute session max defaults to 8h.
ADMIN_IDLE_TIMEOUT_MS=1800000
ADMIN_SESSION_MAX_MS=28800000
# Account lockout after N failed passwords (default 5 / 15 min)
ADMIN_MAX_FAILED_ATTEMPTS=5
ADMIN_LOCKOUT_MS=900000

# Event listener — start at tip; small chunks for Amoy public RPC
EVENT_SYNC_CHUNK_SIZE=100

# Server
PORT=3000
NODE_ENV=development
