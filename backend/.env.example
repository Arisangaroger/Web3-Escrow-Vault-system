# Database
DATABASE_URL="postgresql://user:password@localhost:5432/escrow_db?schema=public"

# Blockchain
RPC_URL="https://rpc-amoy.polygon.technology"
CHAIN_ID=80002
ESCROW_CONTRACT_ADDRESS="0x..."
ERWF_CONTRACT_ADDRESS="0x..."

# Gas Relay / Treasury Wallet
# Pays meta-tx gas AND signs resolveDispute (must hold Escrow ADMIN_ROLE —
# matching local deploy where deployer/ADMIN_ADDRESS receives ADMIN_ROLE).
TREASURY_PRIVATE_KEY="0x..."

# Gas top-up for user wallets when they must send ERC20 approve themselves
GAS_THRESHOLD="0.01"
GAS_TOP_UP_AMOUNT="0.05"

# Security
ENCRYPTION_KEY="your-256-bit-encryption-key-here"
PIN_PEPPER="your-pin-pepper-secret-here"

# Admin Authentication
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="8h"
# Idle logout (default 30 min). Absolute session max defaults to 8h.
ADMIN_IDLE_TIMEOUT_MS=1800000
ADMIN_SESSION_MAX_MS=28800000
# Account lockout after N failed passwords (default 5 / 15 min)
ADMIN_MAX_FAILED_ATTEMPTS=5
ADMIN_LOCKOUT_MS=900000

# Keeper Jobs
KEEPER_INTERVAL_MINUTES=5
EVENT_SYNC_INTERVAL_SECONDS=30

# Server
PORT=3000
NODE_ENV=development
