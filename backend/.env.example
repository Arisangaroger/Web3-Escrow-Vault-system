# Database
DATABASE_URL="postgresql://user:password@localhost:5432/escrow_db?schema=public"

# Blockchain
RPC_URL="https://rpc-amoy.polygon.technology"
CHAIN_ID=80002
ESCROW_CONTRACT_ADDRESS="0x..."
ERWF_CONTRACT_ADDRESS="0x..."

# Gas Relay / Treasury Wallet (pays meta-tx gas; should also have eRWF OPERATOR_ROLE for mint in tests)
TREASURY_PRIVATE_KEY="0x..."

# Optional: Escrow ADMIN_ROLE key for resolveDispute (defaults to TREASURY_PRIVATE_KEY)
ADMIN_PRIVATE_KEY=

# Gas top-up for user wallets when they must send ERC20 approve themselves
GAS_THRESHOLD="0.01"
GAS_TOP_UP_AMOUNT="0.05"

# Security
ENCRYPTION_KEY="your-256-bit-encryption-key-here"
PIN_PEPPER="your-pin-pepper-secret-here"

# Admin Authentication
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="8h"

# Keeper Jobs
KEEPER_INTERVAL_MINUTES=5
EVENT_SYNC_INTERVAL_SECONDS=30

# Server
PORT=3000
NODE_ENV=development
