{
  "name": "escrow-backend",
  "version": "1.0.0",
  "description": "Backend bridge for blockchain escrow system",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "sync:abis": "node -e \"const fs=require('fs');const path=require('path');const src=path.join('..','blockchain','artifacts','contracts');const dest=path.join('src','modules','contracts','abis');fs.mkdirSync(dest,{recursive:true});fs.copyFileSync(path.join(src,'Escrow.sol','Escrow.json'),path.join(dest,'Escrow.json'));fs.copyFileSync(path.join(src,'eRWF.sol','eRWF.json'),path.join(dest,'eRWF.json'));console.log('ABIs synced');\""
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/schedule": "^4.0.0",
    "@prisma/client": "^5.7.0",
    "ethers": "^6.14.0",
    "argon2": "^0.31.2",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/jest": "^29.5.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "jest": "^29.5.0",
    "prisma": "^5.7.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
